# Supabase — get these from your project's Settings > API page
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon/public key>
SUPABASE_SERVICE_ROLE_KEY=<service role key — never expose client-side>

# Encryption key for Granola API keys and Monday.com tokens stored in the DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Server port (default: 3000)
PORT=3000

# ---- Phase 2 ----
# Base URL of this app — used for OAuth redirect URIs
APP_URL=http://localhost:3000

# Monday.com OAuth app credentials (create app at developer.monday.com)
# Set redirect URI to: <APP_URL>/auth/monday/callback
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=

# ---- Added in Phase 4 ----
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=

# ---- Added in Phase 3 ----
# ANTHROPIC_API_KEY=

# ---- Added in Phase 6 ----
# ADMIN_TOKEN=
